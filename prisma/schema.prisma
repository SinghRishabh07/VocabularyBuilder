generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum PartOfSpeech {
  noun
  verb
  adjective
  adverb
}

model User {
  id        String    @id @default(uuid())
  googleId  String    @unique
  email     String    @unique
  name      String?
  image     String?
  /// Target words to add per day (progress daily goal)
  dailyWordGoal Int     @default(5)
  /// YYYY-MM-DD (UTC) when we last sent a “streak at risk” email (prevents duplicate sends)
  streakRemindYmd String?
  /// In-app: level up pending until user sees dismiss (null = no pending)
  levelUpFrom  Int?
  levelUpTo    Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  sessions Session[]
  words    Word[]
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

model Word {
  id         String   @id @default(uuid())
  word       String
  createdAt  DateTime @default(now())
  isFavorite Boolean  @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  meanings Meaning[]

  @@unique([userId, word])
}

model Meaning {
  id                String       @id @default(uuid())
  type              PartOfSpeech // 2. Applied the enum here
  dictionaryMeaning String?
  personalMeaning   String?

  wordId            String
  word              Word         @relation(fields: [wordId], references: [id], onDelete: Cascade)

  examples          Example[]
}

model Example {
  id                String  @id @default(uuid())
  dictionaryExample String?
  personalExample   String?

  meaningId         String
  meaning           Meaning @relation(fields: [meaningId], references: [id], onDelete: Cascade)
}